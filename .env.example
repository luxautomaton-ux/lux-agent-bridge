PORT=8787

# Comma-separated list of allowed local origins in development.
# Example: http://localhost:3000,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173

# Where OpenManus lives on your machine.
OPENMANUS_DIR=/absolute/path/to/OpenManus

# Optional local model endpoint to health-check.
LOCAL_MODEL_HEALTH_URL=http://127.0.0.1:11434/api/tags

# Restrict project operations to these roots.
# If empty, defaults to the local ./projects folder.
ALLOWED_PROJECT_ROOTS=

# Require approval for autonomous task runs.
REQUIRE_APPROVAL_AUTONOMOUS=true

# Optional API token for all /api requests.
# If set, send this in `x-lux-token` from the UI.
LUX_API_TOKEN=

# Keep this true for private local mode.
ALLOW_LOCALHOST_ONLY=true

# Relay server settings (optional)
RELAY_PORT=9797
RELAY_KEY=
BRIDGE_BASE_URL=http://127.0.0.1:8787
RELAY_ALLOWLIST=
RELAY_RATE_LIMIT_WINDOW_MS=60000
RELAY_RATE_LIMIT_MAX=120
