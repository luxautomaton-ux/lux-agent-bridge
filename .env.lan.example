PORT=8787

# For phone/tablet access on same Wi-Fi, add your host machine LAN IP origin:
# Example: http://192.168.1.40:8787
CORS_ORIGINS=http://localhost:8787,http://127.0.0.1:8787,http://192.168.1.40:8787

OPENMANUS_DIR=/absolute/path/to/OpenManus
LOCAL_MODEL_HEALTH_URL=http://127.0.0.1:11434/api/tags
ALLOWED_PROJECT_ROOTS=
REQUIRE_APPROVAL_AUTONOMOUS=true

# Keep token enabled for LAN mode.
LUX_API_TOKEN=replace_with_long_random_token

# Set false to allow LAN devices.
ALLOW_LOCALHOST_ONLY=false
